# Async PostgreSQL (application runtime)
# Use utf8mb4 for full Unicode (recommended).
DATABASE_URL=mysql+aiomysql://root:root@127.0.0.1:3306/tapafix?charset=utf8mb4

# JWT
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_MINUTES=60

# Email provider: auto | sendgrid | smtp | mailtrap
EMAIL_PROVIDER=auto

# SendGrid
SENDGRID_API_KEY=

# Sender + optional frontend reset page URL
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=Tapafix
FRONTEND_PASSWORD_RESET_URL=

# Generic SMTP
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Mailtrap SMTP
MAILTRAP_HOST=live.smtp.mailtrap.io
MAILTRAP_PORT=587
MAILTRAP_USER=
MAILTRAP_PASSWORD=

DEBUG=true
PROJECT_NAME=Tapafix API

# Social OAuth (set for providers you enable)
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
APPLE_CLIENT_ID=
